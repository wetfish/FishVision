{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "App Health",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "up{job=~\"factory-.*\", environment=~\"$environment\"}",
          "legendFormat": "{{ job }} ({{ environment }})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } }, "type": "value" }
          ],
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "title": "Node CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\", job=~\"factory-.*-node\", environment=~\"$environment\"}[5m])) * 100)",
          "legendFormat": "{{ instance }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "min": 0,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 80 }
            ]
          }
        }
      }
    },
    {
      "title": "Node Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes{job=~\"factory-.*-node\", environment=~\"$environment\"} / node_memory_MemTotal_bytes{job=~\"factory-.*-node\", environment=~\"$environment\"})) * 100",
          "legendFormat": "{{ instance }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "min": 0,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "title": "Node Disk Usage",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "(node_filesystem_size_bytes{job=~\"factory-.*-node\", environment=~\"$environment\", fstype!~\"tmpfs|overlay\"} - node_filesystem_free_bytes{job=~\"factory-.*-node\", environment=~\"$environment\", fstype!~\"tmpfs|overlay\"}) / node_filesystem_size_bytes{job=~\"factory-.*-node\", environment=~\"$environment\", fstype!~\"tmpfs|overlay\"} * 100",
          "legendFormat": "{{ instance }} {{ mountpoint }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "min": 0,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "title": "MySQL Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "mysql_global_status_threads_connected{job=~\"factory-mysql-.*\", environment=~\"$environment\"}",
          "legendFormat": "{{ environment }} connections"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "red", "value": 120 }
            ]
          }
        }
      }
    },
    {
      "title": "MySQL Queries Per Second",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(mysql_global_status_queries{job=~\"factory-mysql-.*\", environment=~\"$environment\"}[5m])",
          "legendFormat": "{{ environment }} QPS"
        }
      ]
    },
    {
      "title": "Redis Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "redis_memory_used_bytes{job=~\"factory-redis-.*\", environment=~\"$environment\"}",
          "legendFormat": "{{ environment }} used"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },
    {
      "title": "Redis Connected Clients",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "redis_connected_clients{job=~\"factory-redis-.*\", environment=~\"$environment\"}",
          "legendFormat": "{{ environment }} clients"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["factory", "wetfish"],
  "templating": {
    "list": [
      {
        "name": "environment",
        "type": "custom",
        "current": { "text": "All", "value": "$__all" },
        "options": [
          { "text": "All", "value": "$__all", "selected": true },
          { "text": "staging", "value": "staging", "selected": false },
          { "text": "production", "value": "production", "selected": false }
        ],
        "includeAll": true,
        "multi": false
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "title": "Factory Overview",
  "uid": "factory-overview"
}
